# Copy this file to `.env` or add these values to your run configuration/environment.
# Never commit the real `.env` file.

# Supabase PostgreSQL connection.
# Use the JDBC connection string from Supabase, not Supabase API keys.
# Example format:
# SUPABASE_DB_URL=jdbc:postgresql://aws-0-ap-south-1.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0
SUPABASE_DB_URL=jdbc:postgresql://YOUR_SUPABASE_DB_HOST:6543/postgres?sslmode=require&prepareThreshold=0
SUPABASE_DB_USERNAME=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_DATABASE_PASSWORD

# GitHub OAuth app credentials.
# GitHub Developer Settings -> OAuth Apps -> your Reppo app.
GITHUB_CLIENT_ID=YOUR_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET

# Optional fallbacks supported by application.yaml.
# You can leave these blank if you use the SUPABASE_* variables above.
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=
